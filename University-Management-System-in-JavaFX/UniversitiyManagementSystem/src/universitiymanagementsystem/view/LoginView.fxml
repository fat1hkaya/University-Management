<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="900.0" prefWidth="1440.0" stylesheets="@../../Design/ModernSaaS.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="universitiymanagementsystem.controller.LoginController">
    <children>
        <Region styleClass="login-bg-image" />
        <Region styleClass="login-bg-overlay" />
        <VBox alignment="CENTER" StackPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" maxWidth="420.0" spacing="24.0" styleClass="login-card">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <StackPane>
                                    <Circle radius="32.0" styleClass="login-brand-circle" />
                                    <Label text="MU" textFill="WHITE">
                                        <font>
                                            <Font name="System Bold" size="18.0" />
                                        </font>
                                    </Label>
                                </StackPane>
                                <Label styleClass="login-title" text="Marmara Üniversitesi" />
                                <Label styleClass="login-subtitle" text="Öğrenci Bilgi Sistemi" />
                            </children>
                        </VBox>
                        <VBox spacing="16.0">
                            <children>
                                <VBox spacing="6.0">
                                    <Label styleClass="form-label" text="Kullanıcı Adı" />
                                    <TextField fx:id="usernameField" prefHeight="48.0" promptText="Kullanıcı adınızı girin" styleClass="login-input" />
                                </VBox>
                                <VBox spacing="6.0">
                                    <Label styleClass="form-label" text="Şifre" />
                                    <PasswordField fx:id="passwordField" prefHeight="48.0" promptText="Şifrenizi girin" styleClass="login-input" />
                                </VBox>
                            </children>
                        </VBox>
                        <VBox spacing="10.0">
                            <children>
                                <Button fx:id="loginBtn" maxWidth="1.7976931348623157E308" onAction="#signIn" prefHeight="48.0" styleClass="login-btn" text="Giriş Yap" />
                                <Button maxWidth="1.7976931348623157E308" onAction="#signInEdevlet" prefHeight="44.0" styleClass="edevlet-btn" text="e-Devlet ile Giriş" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Hyperlink onAction="#forgotPassword" styleClass="forgot-link" text="Şifremi Unuttum?" />
                            </children>
                        </HBox>
                        <Label fx:id="statusLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="status-label" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>
